{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "diskSize": {
      "type": "string",
      "default": "10Gi",
      "mutable": true,
      "editDisabled": true
    },
    "customConfig": {
      "type": "string",
      "default": "",
      "mutable": true
    },
    "version": {
      "type": "string",
      "default": "25.3",
      "mutable": true
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "default": "500m",
              "mutable": true
            },
            "memory": {
              "type": "string",
              "default": "512M",
              "mutable": true
            }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "default": "2000m",
              "mutable": true
            },
            "memory": {
              "type": "string",
              "default": "2048M",
              "mutable": true
            }
          }
        }
      }
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "database": {
            "type": "string"
          }
        },
        "required": ["name", "database"]
      }
    }
  }
}
